{
	"name": "smart-transcriber",
	"version": "1.1.0",
	"description": "Simple audio transcription plugin for Obsidian using OpenRouter",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "npm run test:unit && npm run test:acceptance",
		"test:unit": "node --experimental-strip-types --test tests/unit/*.test.ts",
		"test:acceptance": "node --experimental-strip-types --test tests/acceptance/*.test.ts",
		"test-api:audit": "node scripts/audit-test-api.mjs",
		"mutation": "stryker run",
		"coverage": "c8 --all --src src --include 'src/audio-files.ts' --include 'src/note-titles.ts' --include 'src/openrouter.ts' --reporter=text --reporter=json --reporter=json-summary --check-coverage --lines 80 --functions 80 --branches 80 --statements 80 npm test",
		"complexity": "eslint src tests --rule 'complexity: [\"error\", 8]'",
		"crap": "node node_modules/crap4ts/dist/cli.js --coverage coverage/coverage-final.json --src src --include 'src/audio-files.ts' 'src/note-titles.ts' 'src/openrouter.ts' --threshold 30 --coverage-metric branch",
		"duplication": "jscpd",
		"quality": "npm run build && npm run lint && npm run test && npm run coverage && npm run complexity && npm run crap",
		"integrity": "npm run duplication && npm run test-api:audit",
		"integrity:deep": "npm run integrity && npm run mutation",
		"check": "npm run quality && npm run integrity",
		"test:integration": "node --env-file=.env.test --experimental-strip-types --test tests/integration/*.test.ts",
		"push": "cp main.js manifest.json styles.css '/home/oleksii/Documents/Bibliotheka/.obsidian/plugins/test-plugin'"
	},
	"keywords": [],
	"license": "0-BSD",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@stryker-mutator/core": "^9.6.1",
		"@types/node": "^16.11.6",
		"c8": "^11.0.0",
		"crap4ts": "^1.0.1",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"jscpd": "^4.1.0",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1"
	},
	"dependencies": {
		"obsidian": "latest"
	}
}
